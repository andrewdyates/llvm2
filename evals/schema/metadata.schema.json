{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Andrew Yates <ayates@dropbox.com>",
  "type": "object",
  "required": [
    "eval_id",
    "run_id",
    "git_commit",
    "spec_path",
    "runner",
    "started_at"
  ],
  "properties": {
    "eval_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "spec_path": {
      "type": "string"
    },
    "runner": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
