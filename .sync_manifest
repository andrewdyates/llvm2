# Sync Manifest - defines what files sync from ai_template to other repos
# Format: One pattern per line. Supports:
#   - Exact paths: looper.py
#   - Glob patterns: ai_template_scripts/*.py
#   - Directory sync (trailing /): looper/ (CAUTION: uses rsync --delete)
#
# WARNING: Directory sync (trailing /) destroys project-specific files.
# Use file globs or explicit paths for directories with project content.
# See P0 #2550 and designs/2026-02-05-sync-safety-mechanisms.md.
#
# Lines starting with # are comments
# Lines starting with ! are exclusions (processed after includes)
# Special handlers: .gitignore (preserves project-specific entries)

# This manifest (for sync_check.sh drift detection)
.sync_manifest

# Core runner
looper.py
looper/

# AI instruction files
# AGENTS.md is synced as a minimal stub. Codex rules are injected by the looper
# at runtime via build_codex_context(). sync_repo.sh replaces old full AGENTS.md.
AGENTS.md
GEMINI.md

# Community health files
CHANGELOG.md
CODE_OF_CONDUCT.md
SUPPORT.md

# Config files
.claude-version
.codex-version
ruff.toml
requirements.txt
.mcp.json
.gitignore
.pre-commit-config.yaml
.gitleaks.toml

# Rules (individual files, not directory - rules may be project-specific)
.claude/rules/ai_template.md
# org_chart.md is project-specific (each org has its own structure).
# New repos get the template version via gh repo create --template.
# Existing repos maintain their own org_chart.md independently.

# Codex-specific instructions (included in build_codex_context() at runtime)
.claude/codex.md

# Settings - hooks configuration for Claude Code (#1847)
.claude/settings.json

# Roles and commands - file-level sync to preserve project-specific content (#2551)
# Uses glob patterns instead of directory sync (rsync --delete) which destroys
# project-specific commands and role customizations. See P0 #2550.
.claude/roles/*.md
.claude/commands/*.md

# Plugins - sync specific plugin directories, NOT entire .claude/plugins/
# This preserves project-specific plugins in downstream repos (#1369)
.claude/plugins/tab-title/

# Script module directories (multi-file packages; not covered by *.py glob)
ai_template_scripts/bg_task/
ai_template_scripts/cargo_wrapper/
ai_template_scripts/code_stats/
ai_template_scripts/crash_analysis/
ai_template_scripts/gh_apps/
ai_template_scripts/gh_post/
ai_template_scripts/gh_rate_limit/
ai_template_scripts/headers/
ai_template_scripts/health_check/
ai_template_scripts/hooks/
ai_template_scripts/json_to_text/
ai_template_scripts/lib/
ai_template_scripts/mcp/
ai_template_scripts/pulse/
ai_template_scripts/templates/

# Scripts - glob all .sh and .py files
ai_template_scripts/*.sh
ai_template_scripts/*.py
ai_template_scripts/bin/cargo
ai_template_scripts/bin/gh
ai_template_scripts/bin/git
ai_template_scripts/bin/grep
ai_template_scripts/bin/python3
ai_template_scripts/README.md

# Templates - explicit files to preserve project-specific templates (#2551)
templates/cargo_config.toml
templates/clippy.toml
templates/success_metrics.md
postmortems/TEMPLATE.md
tests/conftest.py
tests/test_example.py

# Benchmark templates - explicit files to preserve project-specific benchmarks (#2551)
benchmarks/templates/docker-compose.yaml
benchmarks/templates/Dockerfile
benchmarks/templates/run_eval.sh
benchmarks/README.md

# Documentation (merge mode - add/update template docs, preserve project docs)
# Uses glob instead of directory sync to avoid --delete wiping project-specific files
docs/*.md

# Diagrams
diagrams/issue-workflow.md

# Eval schemas
evals/schema/registry.schema.yaml
evals/schema/metadata.schema.json
evals/schema/results.schema.json

# Exclusions - never sync these even if they match above
!ai_template_scripts/__pycache__/
!**/*.pyc
!.looper_config.json
!.pre-commit-local.d/
!.gh_apps_creds.enc
!ait_identity.toml
