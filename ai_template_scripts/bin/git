#!/usr/bin/env bash
# git wrapper - Blocks branch creation, guards destructive ops, serializes commits
#
# CANONICAL SOURCE: ayates_dbx/ai_template
# DO NOT EDIT in other repos - file issues to ai_template for changes.
#
# This wrapper sits in PATH before the real git and:
# - Blocks branch-creating commands (branch <name>, checkout -b, switch -c)
# - Blocks git stash operations (stash push/pop/apply/drop) - use WIP commits instead
# - Guards destructive operations when workers active (restore, checkout --, reset --hard, clean -f)
# - Serializes git commit operations with a per-repo lock to prevent collisions
# - Isolates worker staging via per-worker GIT_INDEX_FILE (#3197)
# - Blocks --no-verify/-n on git commit for AI roles unless explicitly allowed
# - Auto-installs the commit-msg hook on git commit if missing (when hook source exists)
# - Passes all other commands to the real git unchanged
#
# Installed by looper.py via PATH modification.
#
# Destructive op guard:
#   When .pid_worker or .pid_worker_* files exist with valid processes, blocks:
#   - git restore <path>     (unless --staged)
#   - git checkout -- <path>
#   - git reset --hard
#   - git clean -f/-fd
#   Use --ait-force-destructive to override if needed.
#
# Config:
#   AI_ROLE              - WORKER/PROVER/RESEARCHER/MANAGER/USER (set by looper.py)
#   AIT_ALLOW_NO_VERIFY  - Set to 1 to allow --no-verify/-n for AI roles on git commit
#   AIT_GIT_LOCK_WAIT_S  - Seconds to wait for lock (default: 300, see also .looper_config.json)
#   AIT_GIT_LOCK_STATUS_INTERVAL_S - Seconds between lock-wait progress lines (default: 60)
#   AIT_GIT_LOCK_DISABLE - Set to 1 to disable commit locking
#
# Per-repo config (.looper_config.json):
#   git_lock_wait_sec    - Seconds to wait for commit lock (overrides AIT_GIT_LOCK_WAIT_S)
#
# Author: Andrew Yates <ayates@dropbox.com>
# Copyright 2026 Dropbox, Inc.
# Licensed under the Apache License, Version 2.0

# Find the real git (skip this wrapper)
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REAL_GIT=""

# First try common locations (fastest, avoids PATH issues)
for loc in /usr/bin/git /opt/homebrew/bin/git /usr/local/bin/git; do
    if [[ -x "$loc" ]]; then
        candidate_real="$(realpath "$loc" 2>/dev/null || echo "$loc")"
        [[ "$candidate_real" != "$SCRIPT_PATH" ]] && REAL_GIT="$loc" && break
    fi
done

# Fall back to PATH search if not found
if [[ -z "$REAL_GIT" ]]; then
    IFS=':' read -ra PATH_DIRS <<<"$PATH"
    for p in "${PATH_DIRS[@]}"; do
        [[ -d "$p" ]] || continue
        git_candidate="$p/git"
        [[ -x "$git_candidate" ]] || continue
        candidate_real="$(realpath "$git_candidate" 2>/dev/null || echo "$git_candidate")"
        [[ "$candidate_real" == "$SCRIPT_PATH" ]] && continue
        REAL_GIT="$git_candidate"
        break
    done
fi

if [[ -z "$REAL_GIT" ]]; then
    echo "ERROR: Real git not found in PATH" >&2
    exit 1
fi

# Check if branch name is allowed (zone/* for multi-machine mode)
is_zone_branch() {
    local branch="$1"
    [[ "$branch" == zone/* ]]
}

# Block branch-creating commands (unless zone/* for multi-machine mode)
block_branch() {
    local branch="${1:-}"
    if [[ -n "$branch" ]] && is_zone_branch "$branch"; then
        return 0 # Allow zone/* branches for multi-machine mode
    fi
    cat >&2 <<'EOF'
ERROR: Branch creation is blocked.

AI workers must commit directly to main. Branches create:
- Merge conflicts that AIs cannot resolve
- Orphan branches when sessions end
- Coordination complexity across workers

See ai_template rule: "No feature branches"

Exception: zone/* branches are allowed for multi-machine mode.
If you need to isolate work, commit small incremental changes to main.
EOF
    exit 1
}

# Check if workers are active (any .pid_worker or .pid_worker_* with valid process)
workers_active() {
    local repo_root
    repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -z "$repo_root" ]] && return 1

    # Check both single-worker (.pid_worker) and multi-worker (.pid_worker_*) formats
    for pidfile in "$repo_root"/.pid_worker "$repo_root"/.pid_worker_*; do
        [[ -f "$pidfile" ]] || continue
        local pid
        pid="$(cat "$pidfile" 2>/dev/null || true)"
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            return 0 # At least one worker is active
        fi
    done
    return 1
}

# Warn and block destructive operations when workers active
block_destructive() {
    local op="$1"
    local repo_root
    repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || echo .)"
    local worker_count
    # Count both single-worker (.pid_worker) and multi-worker (.pid_worker_*) files
    worker_count="$(find "$repo_root" -maxdepth 1 \( -name '.pid_worker' -o -name '.pid_worker_*' \) 2>/dev/null | wc -l)"
    worker_count="${worker_count//[[:space:]]/}"
    printf '%s\n' \
        "ERROR: Destructive operation blocked while workers are active." \
        "" \
        "Command: git ${op}" \
        "Workers: ${worker_count} worker process(es) active" \
        "" \
        "This command may revert uncommitted worker changes. Options:" \
        "1. Wait for workers to commit their changes" \
        "2. Use --ait-force-destructive to override (after verifying no uncommitted work)" \
        "" \
        "See ai_template rule: \"Commit AND push: Files invisible until pushed\"" >&2
    exit 1
}

# Check for --ait-force-destructive override flag
has_force_override() {
    for arg in "$@"; do
        [[ "$arg" == "--ait-force-destructive" ]] && return 0
    done
    return 1
}

# Remove --ait-force-destructive from args and exec real git
# Uses exec directly to preserve argument quoting (avoids word splitting issues)
exec_without_force_flag() {
    local -a new_args=()
    for arg in "$@"; do
        [[ "$arg" != "--ait-force-destructive" ]] && new_args+=("$arg")
    done
    exec "$REAL_GIT" "${new_args[@]}"
}

# Block --no-verify for AI roles to prevent bypassing commit hooks
has_no_verify() {
    for arg in "$@"; do
        [[ "$arg" == "--no-verify" || "$arg" == "-n" ]] && return 0
    done
    return 1
}

is_ai_role() {
    case "${AI_ROLE:-}" in
    WORKER | PROVER | RESEARCHER | MANAGER) return 0 ;;
    *) return 1 ;;
    esac
}

is_worker_role() {
    [[ "${AI_ROLE:-}" == "WORKER" ]]
}

extract_role_from_git_identity() {
    local identity_name="${1:-}"
    [[ -z "$identity_name" ]] && return 0

    local normalized_name
    normalized_name="$(printf '%s' "$identity_name" | tr '[:upper:]' '[:lower:]')"

    # setup_git_identity() uses "{project}-{role}-{iteration}".
    if [[ "$normalized_name" =~ -worker-[0-9]+$ ]]; then
        echo "WORKER"
    elif [[ "$normalized_name" =~ -prover-[0-9]+$ ]]; then
        echo "PROVER"
    elif [[ "$normalized_name" =~ -researcher-[0-9]+$ ]]; then
        echo "RESEARCHER"
    elif [[ "$normalized_name" =~ -manager-[0-9]+$ ]]; then
        echo "MANAGER"
    fi
}

validate_git_identity_role() {
    if ! is_ai_role; then
        return 0
    fi

    local identity_var identity_name detected_role
    for identity_var in GIT_AUTHOR_NAME GIT_COMMITTER_NAME; do
        identity_name="${!identity_var:-}"
        [[ -z "$identity_name" ]] && continue

        detected_role="$(extract_role_from_git_identity "$identity_name")"
        [[ -z "$detected_role" ]] && continue

        if [[ "$detected_role" != "${AI_ROLE:-}" ]]; then
            echo "ERROR: Git identity role mismatch (#2958)" >&2
            echo "   ${identity_var}=${identity_name} implies ${detected_role}, but AI_ROLE=${AI_ROLE}" >&2
            echo "   This can happen when role-specific git identity leaks across sessions." >&2
            echo "   Re-run looper identity setup before committing." >&2
            exit 1
        fi
    done
}

# Get git_lock_wait_sec from .looper_config.json if present (default: 300)
get_git_lock_wait_sec() {
    local repo_root config_file value
    repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -z "$repo_root" ]] && echo "300" && return

    config_file="$repo_root/.looper_config.json"
    [[ -f "$config_file" ]] || {
        echo "300"
        return
    }

    # Try to extract git_lock_wait_sec using python3 (portable JSON parsing)
    if command -v python3 &>/dev/null; then
        value=$(python3 -c "
import json
import sys
try:
    with open('$config_file') as f:
        data = json.load(f)
    val = data.get('git_lock_wait_sec')
    if val is not None and isinstance(val, int) and val > 0:
        print(val)
    else:
        print('300')
except Exception:
    print('300')
" 2>/dev/null || echo "300")
        echo "$value"
    else
        # No python3, fall back to default
        echo "300"
    fi
}

# Parse git global flags to find the actual subcommand.
# Git grammar: git [global-flags] <subcommand> [subcommand-args]
# Sets GIT_SUBCMD to the subcommand and GIT_SUBCMD_POS to its 1-based
# position in "$@" (so subcommand args start at position GIT_SUBCMD_POS+1).
# If no subcommand found, GIT_SUBCMD="" and GIT_SUBCMD_POS=0.
parse_git_subcommand() {
    GIT_SUBCMD=""
    GIT_SUBCMD_POS=0
    local pos=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
        # Global flags that take a value argument
        -C | -c | --git-dir | --work-tree | --namespace | --super-prefix | --config-env)
            shift 2 || return # skip flag + value
            pos=$((pos + 2))
            ;;
        # Global flags with = syntax (already consume value)
        --git-dir=* | --work-tree=* | --namespace=* | --super-prefix=* | --config-env=* | -c*)
            # -c can be -ckey=value (no space)
            shift
            pos=$((pos + 1))
            ;;
        # --exec-path with optional =value (--exec-path alone is a query, not flag+value)
        --exec-path=* | --exec-path)
            shift
            pos=$((pos + 1))
            ;;
        # Global boolean flags (no value)
        --bare | --no-replace-objects | --literal-pathspecs | --glob-pathspecs | --noglob-pathspecs | --icase-pathspecs | --no-optional-locks | --no-lazy-fetch | --no-advice | --html-path | --man-path | --info-path | --paginate | -p | --no-pager | --version | --help)
            shift
            pos=$((pos + 1))
            ;;
        -*)
            # Unknown flag - assume it's a global flag and skip.
            # This is conservative: better to skip an unknown flag and
            # reach the subcommand than to misidentify a flag as a subcommand.
            shift
            pos=$((pos + 1))
            ;;
        *)
            # First non-flag argument is the subcommand
            GIT_SUBCMD="$1"
            GIT_SUBCMD_POS=$pos
            return
            ;;
        esac
    done
}

# Commands that require index isolation in multi-worker mode.
needs_index_isolation() {
    case "$GIT_SUBCMD" in
    add | commit | status | diff | restore | reset | checkout | rm | mv) return 0 ;;
    *) return 1 ;;
    esac
}

# Run real git with preserved global flags (e.g., -C, --git-dir).
git_with_globals() {
    "$REAL_GIT" "${GLOBAL_ARGS[@]}" "$@"
}

# Resolve worker-specific index file paths.
# Sets WORKER_INDEX_PATH and WORKER_INDEX_BASE_FILE on success.
get_worker_index_paths() {
    WORKER_INDEX_PATH=""
    WORKER_INDEX_BASE_FILE=""

    local git_dir repo_root
    git_dir="$(git_with_globals rev-parse --git-dir 2>/dev/null || true)"
    [[ -z "$git_dir" ]] && return 1

    if [[ "$git_dir" != /* ]]; then
        repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
        [[ -n "$repo_root" ]] || return 1
        git_dir="${repo_root}/${git_dir#./}"
    fi
    [[ -d "$git_dir" ]] || return 1

    WORKER_INDEX_PATH="${git_dir%/}/index.worker_${AI_WORKER_ID}"
    WORKER_INDEX_BASE_FILE="${WORKER_INDEX_PATH}.base_head"
    return 0
}

get_current_head_ref() {
    local head_ref
    head_ref="$(git_with_globals rev-parse --verify --quiet HEAD 2>/dev/null || true)"
    if [[ -z "$head_ref" ]]; then
        echo "UNBORN"
    else
        echo "$head_ref"
    fi
}

# Resolve shared index file path (.git/index), respecting global git flags (-C, etc.)
get_shared_index_path() {
    local shared_index repo_root
    shared_index="$(git_with_globals rev-parse --git-path index 2>/dev/null || true)"
    [[ -n "$shared_index" ]] || return 1

    if [[ "$shared_index" != /* ]]; then
        repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
        [[ -n "$repo_root" ]] || return 1
        shared_index="${repo_root}/${shared_index#./}"
    fi
    echo "$shared_index"
    return 0
}

# Initialize index file from a specific HEAD ref.
# Uses a temp file + rename to avoid partially-written indexes.
init_worker_index_from_head() {
    local index_path="$1"
    local head_ref="$2"
    local tmp_index="${index_path}.tmp.$$"

    rm -f "$tmp_index" 2>/dev/null || true

    if [[ "$head_ref" == "UNBORN" ]]; then
        : >"$tmp_index" || return 1
    else
        if ! GIT_INDEX_FILE="$tmp_index" git_with_globals read-tree "$head_ref" >/dev/null 2>&1; then
            rm -f "$tmp_index" 2>/dev/null || true
            return 1
        fi
    fi

    if ! mv "$tmp_index" "$index_path" 2>/dev/null; then
        rm -f "$tmp_index" 2>/dev/null || true
        return 1
    fi
    return 0
}

# Initialize worker index from shared index snapshot when available.
# Falls back to HEAD-based initialization (same behavior as previous versions).
init_worker_index_from_shared_or_head() {
    local index_path="$1"
    local head_ref="$2"
    local tmp_index="${index_path}.tmp.$$"
    local shared_index

    rm -f "$tmp_index" 2>/dev/null || true

    shared_index="$(get_shared_index_path 2>/dev/null || true)"
    if [[ -n "$shared_index" && -f "$shared_index" ]]; then
        if cp "$shared_index" "$tmp_index" 2>/dev/null && mv "$tmp_index" "$index_path" 2>/dev/null; then
            return 0
        fi
        rm -f "$tmp_index" 2>/dev/null || true
    fi

    init_worker_index_from_head "$index_path" "$head_ref"
}

# If worker index is clean but shared index has staged files, adopt shared staged
# state for read/commit commands. This handles staging done outside the wrapper
# (e.g., /usr/bin/git add) without silently skipping pre-commit checks.
adopt_shared_index_when_worker_clean() {
    local head_ref="$1"
    local worker_staged shared_staged

    case "$GIT_SUBCMD" in
    diff | status | commit) ;;
    *) return 0 ;;
    esac

    worker_staged="$(GIT_INDEX_FILE="$WORKER_INDEX_PATH" git_with_globals diff --cached --name-only 2>/dev/null || true)"
    [[ -n "$worker_staged" ]] && return 0

    # Use --diff-filter=ACMR to detect real staged additions/modifications.
    # A stale shared index (behind HEAD after another worker commits) shows
    # deletions in diff --cached which are artifacts, not intentional staging.
    shared_staged="$(git_with_globals diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)"

    # Also detect intentional deletions (#3255): D entries where the file is
    # absent from the working tree are real (e.g., /usr/bin/git rm). D entries
    # where the file exists on disk are stale artifacts from another worker's commit.
    local has_real_deletion=0
    if [[ -z "$shared_staged" ]]; then
        local shared_deletions repo_root
        shared_deletions="$(git_with_globals diff --cached --name-only --diff-filter=D 2>/dev/null || true)"
        if [[ -n "$shared_deletions" ]]; then
            repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
            while IFS= read -r file; do
                [[ -n "$file" ]] || continue
                if [[ ! -e "${repo_root}/${file}" ]]; then
                    has_real_deletion=1
                    break
                fi
            done <<<"$shared_deletions"
        fi
    fi

    [[ -n "$shared_staged" || "$has_real_deletion" -eq 1 ]] || return 0

    if init_worker_index_from_shared_or_head "$WORKER_INDEX_PATH" "$head_ref"; then
        printf '%s\n' "$head_ref" >"$WORKER_INDEX_BASE_FILE" 2>/dev/null || true
        echo "[git wrapper] WARNING: Worker index W${AI_WORKER_ID} adopted staged entries from shared index; prefer staging via wrapper git." >&2
    else
        echo "[git wrapper] WARNING: Failed to adopt shared staged entries for worker index W${AI_WORKER_ID}." >&2
    fi
    return 0
}

# Configure per-worker index isolation for multi-worker staging (#3197).
# Safety: if HEAD changed since last sync, refresh index. For commit with staged
# files in a stale index, block and require restage to avoid silent reverts.
setup_worker_index_isolation() {
    [[ -n "${AI_WORKER_ID:-}" ]] || return 0
    [[ "${AI_WORKER_ID:-}" =~ ^[0-9]+$ ]] || return 0
    [[ -z "${GIT_INDEX_FILE:-}" ]] || return 0

    local head_ref base_head staged_files just_refreshed=0
    if ! get_worker_index_paths; then
        return 0
    fi

    head_ref="$(get_current_head_ref)"

    if [[ ! -f "$WORKER_INDEX_PATH" ]]; then
        # For read/commit commands, seed from shared index to preserve staged
        # files created outside the wrapper. For mutating commands, initialize
        # from HEAD to avoid copying stale stat cache from shared index.
        if [[ "$GIT_SUBCMD" == "diff" || "$GIT_SUBCMD" == "status" || "$GIT_SUBCMD" == "commit" ]]; then
            if ! init_worker_index_from_shared_or_head "$WORKER_INDEX_PATH" "$head_ref"; then
                echo "[git wrapper] WARNING: Failed to initialize worker index; using shared index." >&2
                return 0
            fi
        elif ! init_worker_index_from_head "$WORKER_INDEX_PATH" "$head_ref"; then
            echo "[git wrapper] WARNING: Failed to initialize worker index; using shared index." >&2
            return 0
        fi
        printf '%s\n' "$head_ref" >"$WORKER_INDEX_BASE_FILE" 2>/dev/null || true
    else
        base_head=""
        if [[ -f "$WORKER_INDEX_BASE_FILE" ]]; then
            base_head="$(cat "$WORKER_INDEX_BASE_FILE" 2>/dev/null || true)"
        fi

        if [[ "$base_head" != "$head_ref" ]]; then
            local diff_base="$base_head"
            if [[ -z "$diff_base" ]]; then
                diff_base="$head_ref"
            fi
            staged_files="$(GIT_INDEX_FILE="$WORKER_INDEX_PATH" git_with_globals diff --cached --name-only "$diff_base" 2>/dev/null || true)"

            if ! init_worker_index_from_head "$WORKER_INDEX_PATH" "$head_ref"; then
                echo "[git wrapper] WARNING: Failed to refresh stale worker index; using shared index." >&2
                return 0
            fi
            printf '%s\n' "$head_ref" >"$WORKER_INDEX_BASE_FILE" 2>/dev/null || true
            just_refreshed=1

            if [[ -n "$staged_files" ]]; then
                if [[ "$GIT_SUBCMD" == "commit" ]]; then
                    echo "ERROR: Worker index W${AI_WORKER_ID} was refreshed after HEAD changed." >&2
                    echo "  Restage and recommit these files:" >&2
                    while IFS= read -r file; do
                        [[ -n "$file" ]] && echo "    $file" >&2
                    done <<<"$staged_files"
                    return 1
                fi
                echo "[git wrapper] WARNING: Worker index W${AI_WORKER_ID} refreshed after HEAD changed; re-stage intended files." >&2
            fi
        fi
    fi

    # Skip adoption if index was just refreshed due to HEAD change (#3246).
    # Adopting shared index after a refresh can undo the safety reset.
    if [[ "$just_refreshed" -eq 0 ]]; then
        adopt_shared_index_when_worker_clean "$head_ref"
    fi

    export GIT_INDEX_FILE="$WORKER_INDEX_PATH"
    return 0
}

ensure_commit_msg_hook() {
    local repo_root hook_source hooks_dir hook_target
    repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -z "$repo_root" ]] && return 0

    hook_source="$repo_root/ai_template_scripts/commit-msg-hook.sh"
    [[ -f "$hook_source" ]] || return 0

    hooks_dir="$(git_with_globals rev-parse --git-path hooks 2>/dev/null || echo "$repo_root/.git/hooks")"
    if [[ "$hooks_dir" != /* ]]; then
        hooks_dir="${repo_root}/${hooks_dir#./}"
    fi
    hook_target="$hooks_dir/commit-msg"

    # Install if missing, not executable, or stale compared to source (#2958).
    # Stale hooks miss critical checks like cross-role prefix enforcement and
    # forensic trailers. The source hook has a re-exec mechanism, but the
    # installed hook may predate that mechanism.
    local needs_install=false
    if [[ ! -x "$hook_target" ]]; then
        needs_install=true
    elif ! cmp -s "$hook_source" "$hook_target" 2>/dev/null; then
        needs_install=true
    fi

    if [[ "$needs_install" == "true" ]]; then
        mkdir -p "$hooks_dir" 2>/dev/null || true
        if cp "$hook_source" "$hook_target" && chmod +x "$hook_target"; then
            echo "[git wrapper] Installed commit-msg hook at $hook_target" >&2
        else
            echo "ERROR: Failed to install commit-msg hook at $hook_target" >&2
            echo "   Run ./ai_template_scripts/install_hooks.sh to install hooks." >&2
            exit 1
        fi
    fi
}

# Parse global flags to find the actual subcommand (#3021).
# Without this, `git -C /path commit ...` would bypass all guards because
# $1 would be "-C", not "commit".
parse_git_subcommand "$@"

# Extract global args (everything before the subcommand).
# Needed for helper git calls that must honor -C/--git-dir context.
GLOBAL_ARGS=()
if [[ $GIT_SUBCMD_POS -gt 1 ]]; then
    local_pos=0
    for arg in "$@"; do
        local_pos=$((local_pos + 1))
        if [[ $local_pos -lt $GIT_SUBCMD_POS ]]; then
            GLOBAL_ARGS+=("$arg")
        fi
    done
fi

# Extract subcommand-specific args (everything after the subcommand).
# Guards must iterate SUBCMD_ARGS, not "$@", to avoid confusing global flags
# (e.g., -C <path>) with subcommand flags (e.g., switch -C <branch>).
SUBCMD_ARGS=()
if [[ $GIT_SUBCMD_POS -gt 0 ]]; then
    local_pos=0
    for arg in "$@"; do
        local_pos=$((local_pos + 1))
        if [[ $local_pos -gt $GIT_SUBCMD_POS ]]; then
            SUBCMD_ARGS+=("$arg")
        fi
    done
fi

# Save original args for passthrough to real git (includes global flags).
ORIG_ARGS=("$@")

# Multi-worker safety: isolate index for commands that read/write staged state.
if needs_index_isolation; then
    if ! setup_worker_index_isolation; then
        exit 1
    fi
fi

# Dispatch on the actual subcommand (not $1 which may be a global flag)
case "$GIT_SUBCMD" in
branch)
    # Allow: git branch (list), git branch -d/-D (delete), git branch -a/--list/--show-current
    # Block: git branch <name> (creates branch) unless zone/*
    # Block: git branch -c/-C/--copy <old> <new> (copy creates branch) unless zone/*
    # Block: git branch -m/-M/--move <old> <new> (move creates new name) unless zone/*
    # Parse only subcmd args to avoid confusing global -C with branch -C (copy).
    set -- "${SUBCMD_ARGS[@]}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -c | -C | --copy | -m | -M | --move)
            # Copy/move: `git branch -c [old] <new>` or `git branch -m [old] <new>`
            # The LAST positional arg after the flag is the new branch name.
            shift
            new_name=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                -*) shift ;; # skip additional flags (e.g. --force)
                *)
                    new_name="$1"
                    shift
                    ;;
                esac
            done
            if [[ -n "$new_name" ]]; then
                block_branch "$new_name"
            fi
            # If block_branch allowed it (zone/*) or no name given, pass through
            exec "$REAL_GIT" "${ORIG_ARGS[@]}"
            ;;
        -d | -D | --delete | -a | --all | --list | --show-current | -v | -vv | --verbose | -r | --remotes | --merged | --no-merged | --contains | --no-contains | --sort=* | --format=*)
            # Safe flags - pass through with original args (preserves global flags)
            exec "$REAL_GIT" "${ORIG_ARGS[@]}"
            ;;
        -*)
            # Other flags - continue checking
            shift
            ;;
        *)
            # Positional argument = branch name = creating a branch
            # Allow zone/* for multi-machine mode, block others
            if block_branch "$1"; then
                # zone/* allowed - pass through to real git
                exec "$REAL_GIT" "${ORIG_ARGS[@]}"
            fi
            # block_branch exits on failure, so we never reach here for blocked branches
            ;;
        esac
    done
    # No positional args - safe (listing branches)
    exec "$REAL_GIT" "${ORIG_ARGS[@]}"
    ;;
checkout)
    # Block: git checkout -b <name> unless zone/*
    prev_arg=""
    for arg in "${SUBCMD_ARGS[@]}"; do
        if [[ "$prev_arg" == "-b" || "$prev_arg" == "-B" ]]; then
            # $arg is the branch name after -b/-B
            block_branch "$arg"
        fi
        prev_arg="$arg"
    done
    # Block: git checkout -- <file> when workers active (discards changes)
    # Pattern: checkout followed by -- followed by paths
    has_double_dash=false
    for arg in "${SUBCMD_ARGS[@]}"; do
        [[ "$arg" == "--" ]] && has_double_dash=true && break
    done
    if $has_double_dash && workers_active && ! has_force_override "$@"; then
        block_destructive "checkout -- <paths>"
    fi
    if has_force_override "$@"; then
        exec_without_force_flag "$@"
    fi
    ;;
switch)
    # Block: git switch -c/-C <name> unless zone/*
    prev_arg=""
    for arg in "${SUBCMD_ARGS[@]}"; do
        if [[ "$prev_arg" == "-c" || "$prev_arg" == "-C" || "$prev_arg" == "--create" || "$prev_arg" == "--force-create" ]]; then
            # $arg is the branch name after the create flag
            block_branch "$arg"
        fi
        prev_arg="$arg"
    done
    ;;
restore)
    # Block: git restore <file> when workers active (unless --staged)
    # Allow: git restore --staged (only touches index, not working tree)
    has_staged=false
    for arg in "${SUBCMD_ARGS[@]}"; do
        [[ "$arg" == "--staged" || "$arg" == "-S" ]] && has_staged=true && break
    done
    if ! $has_staged && workers_active && ! has_force_override "$@"; then
        block_destructive "restore <paths>"
    fi
    if has_force_override "$@"; then
        exec_without_force_flag "$@"
    fi
    ;;
reset)
    # Block: git reset --hard when workers active
    has_hard=false
    for arg in "${SUBCMD_ARGS[@]}"; do
        [[ "$arg" == "--hard" ]] && has_hard=true && break
    done
    if $has_hard && workers_active && ! has_force_override "$@"; then
        block_destructive "reset --hard"
    fi
    if has_force_override "$@"; then
        exec_without_force_flag "$@"
    fi
    ;;
clean)
    # Block: git clean -f/-fd/--force when workers active
    has_force=false
    for arg in "${SUBCMD_ARGS[@]}"; do
        # Match -f, -fd, -ffd, etc or --force
        if [[ "$arg" =~ ^-[a-zA-Z]*f ]] || [[ "$arg" == "--force" ]]; then
            has_force=true
            break
        fi
    done
    if $has_force && workers_active && ! has_force_override "$@"; then
        block_destructive "clean -f"
    fi
    if has_force_override "$@"; then
        exec_without_force_flag "$@"
    fi
    ;;
add)
    # Block git add -A / git add . for AI roles (#2405)
    # These can stage other workers' files, sensitive files, or large binaries
    for arg in "${SUBCMD_ARGS[@]}"; do
        if [[ "$arg" == "." || "$arg" == "-A" || "$arg" == "--all" ]]; then
            if is_ai_role; then
                cat >&2 <<EOF
ERROR: 'git add $arg' is blocked for AI roles (#2405).

Always stage specific files by name:
  git add file1.py file2.rs

Using 'git add -A' or 'git add .' can:
- Stage other workers' uncommitted changes
- Include sensitive files (.env, credentials)
- Add large binaries accidentally

See ai_template rule: "No git add -A or git add ."
EOF
                exit 1
            else
                # USER role - just warn
                echo "[git add] WARNING: 'git add $arg' may stage unintended files" >&2
            fi
            break
        fi
    done

    # Multi-worker mode: additional check for files not tracked by this worker
    if [[ -n "${AI_WORKER_ID:-}" ]]; then
        repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null || pwd)"
        tracker_file="$repo_root/.worker_${AI_WORKER_ID}_files.json"

        # Check specific files against tracker
        if [[ -f "$tracker_file" ]] && command -v python3 &>/dev/null; then
            # Get tracked files
            tracked_files=$(python3 -c "
import json
import sys
try:
    with open('$tracker_file') as f:
        data = json.load(f)
    for f in data.get('files', []):
        print(f)
except Exception:
    sys.exit(0)
" 2>/dev/null || true)

            # Check each file argument (subcmd args only, not global flags)
            skip_next=false
            for arg in "${SUBCMD_ARGS[@]}"; do
                # Skip flags and their values
                if $skip_next; then
                    skip_next=false
                    continue
                fi
                case "$arg" in
                -p | --patch | -e | --edit | -i | --interactive | -N | --intent-to-add | --chmod=*)
                    continue
                    ;;
                . | --all | -A)
                    continue
                    ;; # Already warned above
                -*)
                    # Other flags - continue checking
                    continue
                    ;;
                *)
                    # This is a file path - check if tracked
                    if [[ -n "$tracked_files" ]]; then
                        if ! echo "$tracked_files" | grep -qxF "$arg"; then
                            echo "[git add] Advisory: '$arg' is not in worker $AI_WORKER_ID's tracked files" >&2
                        fi
                    fi
                    ;;
                esac
            done
        fi
    fi
    ;;
commit)
    if has_no_verify "${SUBCMD_ARGS[@]}"; then
        if is_ai_role && [[ "${AIT_ALLOW_NO_VERIFY:-}" != "1" ]]; then
            echo "ERROR: --no-verify is blocked for AI roles." >&2
            echo "   Commit hooks enforce issue workflow and role boundaries." >&2
            echo "   Remove --no-verify from the command." >&2
            exit 1
        fi
    fi

    # ENFORCE: AI_ROLE must match role-encoded git identity when present (#2958).
    # This catches leaked Worker identity in Manager sessions even when commit
    # titles are unprefixed and would otherwise pass wrapper pre-checks.
    validate_git_identity_role

    ensure_commit_msg_hook

    # Extract commit message from -m "msg" or -F file (not stdin) for pre-hook checks.
    # Note: Does not handle stdin commits (-F -) - hook catches those if installed.
    # Use SUBCMD_ARGS to avoid confusing global flags with commit flags.
    COMMIT_MSG=""
    PREV_ARG=""
    for arg in "${SUBCMD_ARGS[@]}"; do
        if [[ "$PREV_ARG" == "-m" || "$PREV_ARG" == "--message" ]]; then
            COMMIT_MSG="$arg"
            break
        elif [[ "$PREV_ARG" == "-F" || "$PREV_ARG" == "--file" ]]; then
            if [[ -f "$arg" ]]; then
                COMMIT_MSG="$(cat "$arg" 2>/dev/null || true)"
            fi
            break
        elif [[ "$arg" == --message=* ]]; then
            COMMIT_MSG="${arg#--message=}"
            break
        elif [[ "$arg" == --file=* ]]; then
            _FPATH="${arg#--file=}"
            if [[ -f "$_FPATH" ]]; then
                COMMIT_MSG="$(cat "$_FPATH" 2>/dev/null || true)"
            fi
            break
        elif [[ "$arg" == -m* && ${#arg} -gt 2 ]]; then
            # Concatenated short-form: -m"msg" or -mmsg
            COMMIT_MSG="${arg:2}"
            break
        elif [[ "$arg" == -F* && ${#arg} -gt 2 ]]; then
            # Concatenated short-form: -Fpath
            _FPATH="${arg:2}"
            if [[ -f "$_FPATH" ]]; then
                COMMIT_MSG="$(cat "$_FPATH" 2>/dev/null || true)"
            fi
            break
        fi
        PREV_ARG="$arg"
    done

    # Enforce Worker cannot use Fixes #N (fallback when hook isn't installed)
    # This prevents gamma-crown-style bypasses when hook source is missing (#1269)
    if is_worker_role; then
        if [[ -n "$COMMIT_MSG" ]] && echo "$COMMIT_MSG" | grep -qiE '(^|[^[:alnum:]_])(fix|fixes|fixed|close|closes|closed|resolve|resolves|resolved):?[[:space:]]*(([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)?#[0-9]+)'; then
            echo "ERROR: Worker role cannot close issues with Fixes/Closes/Resolves." >&2
            echo "   Use 'Part of #N' to link without closing." >&2
            echo "   Only MANAGER or USER can close issues." >&2
            exit 1
        fi
    fi

    # ENFORCE: Cross-role prefix mismatch detection (#2958)
    # Block commits where the message prefix role doesn't match AI_ROLE.
    # This is a pre-hook defense layer - the commit-msg hook has the same check,
    # but if the hook is stale or missing, this catches the mismatch.
    if is_ai_role && [[ -n "$COMMIT_MSG" ]]; then
        COMMIT_TITLE=$(echo "$COMMIT_MSG" | head -1)
        # Extract role letter from prefix: [W2]42:, [M]10:, [sat-W1]42:
        MSG_ROLE_CHAR=$(echo "$COMMIT_TITLE" | sed -nE 's/^\[[^]]*-?([UWPRM])[0-9]*\][0-9]+:.*/\1/p')
        if [[ -n "$MSG_ROLE_CHAR" ]]; then
            EXPECTED_ROLE_CHAR=""
            case "${AI_ROLE:-}" in
            WORKER) EXPECTED_ROLE_CHAR="W" ;;
            PROVER) EXPECTED_ROLE_CHAR="P" ;;
            RESEARCHER) EXPECTED_ROLE_CHAR="R" ;;
            MANAGER) EXPECTED_ROLE_CHAR="M" ;;
            esac
            if [[ -n "$EXPECTED_ROLE_CHAR" ]] && [[ "$MSG_ROLE_CHAR" != "$EXPECTED_ROLE_CHAR" ]]; then
                echo "ERROR: Cross-role commit prefix mismatch (#2958)" >&2
                echo "   AI_ROLE=$AI_ROLE expects prefix [${EXPECTED_ROLE_CHAR}] but message has [${MSG_ROLE_CHAR}]" >&2
                echo "   Title: $COMMIT_TITLE" >&2
                echo "" >&2
                echo "   This prevents one role from accidentally committing another role's message." >&2
                echo "   If the prefix was copied from another commit, remove it and let the hook add it." >&2
                exit 1
            fi
        fi
    fi

    # Serialize commits with per-repo lock to prevent cross-session collisions
    if [[ -z "${AIT_GIT_LOCK_DISABLE:-}" ]]; then
        GIT_DIR="$(git_with_globals rev-parse --absolute-git-dir 2>/dev/null || true)"
        if [[ -n "$GIT_DIR" ]]; then
            LOCK_DIR="${GIT_DIR}/ait_commit_lock"
            LOCK_PID_FILE="${LOCK_DIR}/pid"
            # Priority: env var > .looper_config.json > default (300)
            if [[ -n "${AIT_GIT_LOCK_WAIT_S:-}" ]]; then
                LOCK_WAIT_S="$AIT_GIT_LOCK_WAIT_S"
            else
                LOCK_WAIT_S="$(get_git_lock_wait_sec)"
            fi
            LOCK_STATUS_INTERVAL_S="${AIT_GIT_LOCK_STATUS_INTERVAL_S:-60}"
            if [[ ! "$LOCK_STATUS_INTERVAL_S" =~ ^[0-9]+$ ]] || [[ "$LOCK_STATUS_INTERVAL_S" -le 0 ]]; then
                LOCK_STATUS_INTERVAL_S="60"
            fi
            LOCK_REPO_NAME="${AI_PROJECT:-$(basename "$(git_with_globals rev-parse --show-toplevel 2>/dev/null || pwd)")}"
            START_TS="$(date +%s)"

            LAST_STATUS_TS="$START_TS"

            while true; do
                if mkdir "$LOCK_DIR" 2>/dev/null; then
                    echo "$$" >"$LOCK_PID_FILE" 2>/dev/null || true
                    break
                fi

                # Check if lock holder is still alive
                if [[ -f "$LOCK_PID_FILE" ]]; then
                    LOCK_PID="$(cat "$LOCK_PID_FILE" 2>/dev/null || true)"
                    if [[ -n "$LOCK_PID" ]] && ! kill -0 "$LOCK_PID" 2>/dev/null; then
                        # Lock holder died, clean up stale lock
                        rm -rf "$LOCK_DIR"
                        continue
                    fi
                fi

                NOW_TS="$(date +%s)"
                if ((NOW_TS - START_TS >= LOCK_WAIT_S)); then
                    echo "[git commit lock] ERROR: Timed out waiting for lock on ${LOCK_REPO_NAME} (${LOCK_WAIT_S}s)" >&2
                    echo "   Set AIT_GIT_LOCK_DISABLE=1 to bypass if lock is stale." >&2
                    exit 1
                fi

                # Emit progress every 60s to prevent looper silence timeout
                if ((NOW_TS - LAST_STATUS_TS >= LOCK_STATUS_INTERVAL_S)); then
                    WAITED=$((NOW_TS - START_TS))
                    echo "[git commit lock] Waiting for lock on ${LOCK_REPO_NAME}... (${WAITED}s/${LOCK_WAIT_S}s)" >&2
                    LAST_STATUS_TS="$NOW_TS"
                fi

                sleep 0.2
            done

            # shellcheck disable=SC2329  # Used via trap
            cleanup_lock() {
                rm -rf "$LOCK_DIR"
            }
            trap cleanup_lock EXIT INT TERM

            status=0
            "$REAL_GIT" "$@" || status=$?
            exit "$status"
        fi
    fi
    ;;
status)
    # Enhanced git status: show worker file ownership after standard output
    "$REAL_GIT" "$@"
    status_exit=$?

    # Skip ownership info for machine-readable formats (--porcelain, -s, -z, etc.)
    is_machine_format=false
    for arg in "${SUBCMD_ARGS[@]}"; do
        case "$arg" in
        --porcelain | --porcelain=* | -s | --short | -z | --null)
            is_machine_format=true
            break
            ;;
        esac
    done

    # Only show ownership info when status succeeded, in a repo, and human format
    if [[ $status_exit -eq 0 ]] && ! $is_machine_format; then
        repo_root="$(git_with_globals rev-parse --show-toplevel 2>/dev/null)" || repo_root=""

        if [[ -n "$repo_root" ]]; then
            # Check for tracker files
            shopt -s nullglob
            trackers=("$repo_root"/.worker_*_files.json)
            shopt -u nullglob

            if [[ ${#trackers[@]} -gt 0 ]] && command -v python3 &>/dev/null; then
                # Show worker file ownership
                python3 - "$repo_root" "${AI_WORKER_ID:-}" <<'PYEOF'
import json
import os
import re
import sys

repo_root = sys.argv[1]
my_worker_id = sys.argv[2] if len(sys.argv) > 2 else ""

tracker_pattern = re.compile(r'^\.worker_(\d+)_files\.json$')
worker_files = {}

for filename in os.listdir(repo_root):
    match = tracker_pattern.match(filename)
    if not match:
        continue

    filepath = os.path.join(repo_root, filename)
    try:
        with open(filepath) as f:
            data = json.load(f)
        pid = data.get('pid', 0)
        worker_id = data.get('worker_id', 0)
        files = data.get('files', [])

        # Check if PID is alive
        if pid > 0:
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                continue  # Dead PID, skip
            except PermissionError:
                pass  # Process exists

        if worker_id > 0 and files:
            worker_files[worker_id] = files
    except (json.JSONDecodeError, OSError, KeyError):
        continue

if worker_files:
    # Print to stderr to avoid corrupting machine-parseable stdout (#2065)
    print(file=sys.stderr)
    print("Active worker files:", file=sys.stderr)
    for wid in sorted(worker_files.keys()):
        marker = " (you)" if str(wid) == my_worker_id else ""
        files = worker_files[wid]
        print(f"  W{wid}{marker}: {len(files)} file(s)", file=sys.stderr)
        for f in sorted(files)[:5]:
            print(f"    {f}", file=sys.stderr)
        if len(files) > 5:
            print(f"    ... and {len(files) - 5} more", file=sys.stderr)
PYEOF
            fi
        fi
    fi

    exit "$status_exit"
    ;;
stash)
    # Block all git stash operations - "Never stash - always commit (WIP if needed)"
    cat >&2 <<'EOF'
ERROR: git stash is blocked.

AI workers must never stash - stashed changes become invisible context.
Instead, commit your changes (even as WIP commits):

  git add -A && git commit -m "[W]N: WIP - description"

This keeps changes visible in git history and prevents lost work.

See ai_template rule: "Commit AND push: Files invisible until pushed"
EOF
    exit 1
    ;;
esac

# Pass through to real git
exec "$REAL_GIT" "$@"
