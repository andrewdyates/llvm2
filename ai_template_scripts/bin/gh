#!/usr/bin/env bash
# gh wrapper - Transparent rate limiting, caching, and AI identity for GitHub CLI
#
# CANONICAL SOURCE: ayates_dbx/ai_template
# DO NOT EDIT in other repos - file issues to ai_template for changes.
#
# This wrapper sits in PATH before the real gh and:
# - Routes "gh issue create/comment/edit/close" through gh_post.py (AI identity)
# - Blocks AI attribution in PR create body (#1394)
# - All commands go through gh_rate_limit.py for rate limiting and caching
#
# Installed by looper.py via PATH modification.
#
# Copyright 2026 Dropbox, Inc.
# Licensed under the Apache License, Version 2.0

SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
PARENT_DIR="$(dirname "$SCRIPT_DIR")"

print_wrapper_help() {
    cat <<'EOF'
ai_template gh wrapper

Usage:
  gh [--wrapper-help] [--wrapper-version] [--no-wrapper] [--] <gh args>

Behavior:
  - Routes issue create/comment/edit/close/cleanup-closed through gh_post.py
  - All other commands go through gh_rate_limit.py for rate limiting and caching
  - --no-wrapper bypasses identity injection and rate limiting
EOF
}

print_wrapper_version() {
    echo "ai_template gh wrapper"
    if command -v git &>/dev/null; then
        local root_dir
        root_dir="$(cd "$(dirname "$SCRIPT_PATH")/../.." 2>/dev/null && pwd)"
        if [[ -n "$root_dir" ]] && [[ -d "$root_dir/.git" ]]; then
            local git_rev
            git_rev="$(git -C "$root_dir" rev-parse --short HEAD 2>/dev/null || true)"
            if [[ -n "$git_rev" ]]; then
                echo "git: $git_rev"
            fi
        fi
    fi
}

find_real_gh() {
    local real_gh=""
    for loc in /opt/homebrew/bin/gh /usr/local/bin/gh /usr/bin/gh; do
        if [[ -x "$loc" ]]; then
            local candidate_real
            candidate_real="$(realpath "$loc" 2>/dev/null || echo "$loc")"
            [[ "$candidate_real" != "$SCRIPT_PATH" ]] && real_gh="$loc" && break
        fi
    done

    if [[ -z "$real_gh" ]]; then
        echo "ERROR: Real gh not found" >&2
        return 1
    fi

    echo "$real_gh"
}

BYPASS_WRAPPER=""
FILTERED_ARGS=()
for arg in "$@"; do
    case "$arg" in
    --wrapper-help)
        print_wrapper_help
        exit 0
        ;;
    --wrapper-version)
        print_wrapper_version
        exit 0
        ;;
    --no-wrapper)
        BYPASS_WRAPPER="1"
        ;;
    *)
        FILTERED_ARGS+=("$arg")
        ;;
    esac
done

if [[ -n "$BYPASS_WRAPPER" ]]; then
    REAL_GH="$(find_real_gh)" || exit 1
    exec "$REAL_GH" "${FILTERED_ARGS[@]}"
fi

# Pass through local commands that don't hit GitHub API
# These should never be rate limited
case "${FILTERED_ARGS[0]}" in
--version | version | --help | help)
    REAL_GH="$(find_real_gh)" || exit 1
    exec "$REAL_GH" "${FILTERED_ARGS[@]}"
    ;;
esac

# Full local mode: route all gh issue commands to gh_local.py
# This is for development when GitHub API is completely saturated
if [[ "${AIT_LOCAL_MODE:-}" == "full" ]]; then
    GH_LOCAL="${PARENT_DIR}/gh_local.py"
    if [[ -f "$GH_LOCAL" ]]; then
        # Find Python
        LOCAL_PYTHON=""
        for p in python3 python; do
            if command -v "$p" &>/dev/null; then
                LOCAL_PYTHON="$p"
                break
            fi
        done
        if [[ -n "$LOCAL_PYTHON" ]]; then
            exec "$LOCAL_PYTHON" "$GH_LOCAL" "$@"
        fi
    fi
    # Fallback: warn and continue to normal flow
    echo "warning: gh_local.py not found, falling back to normal mode" >&2
fi

# Find Python
PYTHON=""
for p in python3 python; do
    if command -v "$p" &>/dev/null; then
        PYTHON="$p"
        break
    fi
done

if [[ -z "$PYTHON" ]]; then
    echo "ERROR: Python not found" >&2
    exit 1
fi

# Issue create/comment/edit/close/cleanup-closed go through gh_post.py for identity injection
ISSUE_SUBCOMMAND=""
ARGS=("$@")
COMMAND_IDX="-1"
SKIP_NEXT="0"
for ((idx = 0; idx < ${#ARGS[@]}; idx++)); do
    if [[ "$SKIP_NEXT" == "1" ]]; then
        SKIP_NEXT="0"
        continue
    fi
    case "${ARGS[idx]}" in
    -R | --repo | -C | --cwd | --hostname | --config)
        SKIP_NEXT="1"
        continue
        ;;
    -R=* | --repo=* | -C=* | --cwd=* | --hostname=* | --config=*)
        continue
        ;;
    -*)
        continue
        ;;
    *)
        COMMAND_IDX="$idx"
        break
        ;;
    esac
done

if [[ "$COMMAND_IDX" -ge 0 ]] && [[ "${ARGS[COMMAND_IDX]}" == "issue" ]]; then
    SUBCOMMAND_IDX="-1"
    SKIP_NEXT="0"
    for ((idx = COMMAND_IDX + 1; idx < ${#ARGS[@]}; idx++)); do
        if [[ "$SKIP_NEXT" == "1" ]]; then
            SKIP_NEXT="0"
            continue
        fi
        case "${ARGS[idx]}" in
        -R | --repo | -C | --cwd | --hostname | --config)
            SKIP_NEXT="1"
            continue
            ;;
        -R=* | --repo=* | -C=* | --cwd=* | --hostname=* | --config=*)
            continue
            ;;
        -*)
            continue
            ;;
        *)
            SUBCOMMAND_IDX="$idx"
            break
            ;;
        esac
    done
    if [[ "$SUBCOMMAND_IDX" -ge 0 ]]; then
        case "${ARGS[SUBCOMMAND_IDX]}" in
        create | comment | edit | close | cleanup-closed)
            ISSUE_SUBCOMMAND="1"
            ;;
        esac
    fi
fi

# GitHub App token injection (when enabled)
# Each project can have its own GitHub App with independent rate limit quota
# MUST be before issue routing so gh_post.py inherits GH_TOKEN (#2285)
if [[ "${AIT_USE_GITHUB_APPS:-}" == "1" ]]; then
    # Detect repo from --repo flag or current git repo
    REPO=""
    for ((idx = 0; idx < ${#FILTERED_ARGS[@]}; idx++)); do
        case "${FILTERED_ARGS[idx]}" in
        -R | --repo)
            if [[ $((idx + 1)) -lt ${#FILTERED_ARGS[@]} ]]; then
                REPO="${FILTERED_ARGS[$((idx + 1))]}"
                # Extract repo name from owner/repo format
                REPO="${REPO##*/}"
            fi
            break
            ;;
        -R=* | --repo=*)
            REPO="${FILTERED_ARGS[idx]#*=}"
            REPO="${REPO##*/}"
            break
            ;;
        esac
    done

    # Fall back to current git repo name
    if [[ -z "$REPO" ]]; then
        REPO="$(git rev-parse --show-toplevel 2>/dev/null | xargs basename 2>/dev/null)" || true
    fi

    if [[ -n "$REPO" ]]; then
        export AIT_CURRENT_REPO="$REPO" # For rate_state.py (#2279)
        # gh_apps.get_token outputs token to stdout; --quiet suppresses errors
        APP_TOKEN=$("$PYTHON" -m ai_template_scripts.gh_apps.get_token --repo "$REPO" --quiet 2>/dev/null) || true
        if [[ -n "$APP_TOKEN" ]]; then
            export GH_TOKEN="$APP_TOKEN"
            export AIT_GH_APP_ACTIVE="1"
        fi
    fi
fi

if [[ -n "$ISSUE_SUBCOMMAND" ]]; then
    GH_POST="${PARENT_DIR}/gh_post.py"
    if [[ -x "$GH_POST" ]]; then
        exec "$PYTHON" "$GH_POST" "$@"
    fi
fi

# Everything else goes through rate limiter
GH_WRAPPER="${PARENT_DIR}/gh_wrapper.py"

# Block AI attribution in PR create body (#1394, #1397)
# Claude Code's built-in PR template includes forbidden attribution patterns
# Checks: --body, --body-file, and --fill (commit messages)
if [[ "$1" == "pr" ]] && [[ "$2" == "create" ]]; then
    # Save original args before parsing
    ORIGINAL_ARGS=("$@")

    # Extract body content from args
    PR_BODY=""
    BODY_FILE=""
    FILL_MODE=""
    shift 2 # Skip "pr create"
    while [[ $# -gt 0 ]]; do
        case "$1" in
        --body=*)
            PR_BODY="${1#--body=}"
            ;;
        --body | -b)
            shift
            PR_BODY="$1"
            ;;
        --body-file=*)
            BODY_FILE="${1#--body-file=}"
            ;;
        --body-file | -F)
            shift
            BODY_FILE="$1"
            ;;
        --fill | -f | --fill-verbose)
            FILL_MODE="1"
            ;;
        esac
        shift
    done

    # Read body from file if --body-file specified
    if [[ -n "$BODY_FILE" ]] && [[ -f "$BODY_FILE" ]]; then
        PR_BODY="$(cat "$BODY_FILE" 2>/dev/null)"
    fi

    # For --fill mode, scan recent commit messages
    if [[ -n "$FILL_MODE" ]] && [[ -z "$PR_BODY" ]]; then
        # Get commits that would be included in the PR
        # Uses git log from merge-base with the default branch
        DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
        if [[ -z "$DEFAULT_BRANCH" ]]; then
            DEFAULT_BRANCH="main"
        fi
        MERGE_BASE=$(git merge-base HEAD "origin/$DEFAULT_BRANCH" 2>/dev/null)
        if [[ -n "$MERGE_BASE" ]]; then
            PR_BODY="$(git log --pretty=format:'%B' "$MERGE_BASE"..HEAD 2>/dev/null)"
        fi
    fi

    # Check for forbidden AI attribution patterns
    # Patterns anchored to line start to avoid false positives on documentation
    if [[ -n "$PR_BODY" ]]; then
        AI_PATTERNS=(
            "^Co-Authored-By:.*[Cc]laude"
            "^[Gg]enerated with.*[Cc]laude"
            "^🤖.*[Gg]enerated"
        )
        for pattern in "${AI_PATTERNS[@]}"; do
            if echo "$PR_BODY" | grep -qiE "$pattern"; then
                echo "" >&2
                echo "❌ ERROR: PR body contains forbidden AI attribution" >&2
                echo "" >&2
                echo "   Found pattern matching: $pattern" >&2
                echo "" >&2
                echo "   Per ai_template.md: NEVER add Claude/AI attribution." >&2
                echo "   No \"Co-Authored-By: Claude\", no AI signatures." >&2
                echo "   Andrew Yates is the author." >&2
                echo "" >&2
                if [[ -n "$BODY_FILE" ]]; then
                    echo "   Found in --body-file: $BODY_FILE" >&2
                elif [[ -n "$FILL_MODE" ]]; then
                    echo "   Found in commit messages (--fill mode)" >&2
                fi
                echo "   Remove the AI attribution line and retry." >&2
                echo "" >&2
                exit 1
            fi
        done
    fi
    # Restore original args and fall through to rate limiter
    set -- "${ORIGINAL_ARGS[@]}"
fi

if [[ -f "$GH_WRAPPER" ]]; then
    exec "$PYTHON" "$GH_WRAPPER" "$@"
fi

# Fallback: find and use real gh directly
REAL_GH="$(find_real_gh)" || exit 1
exec "$REAL_GH" "$@"
